<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Atmosphere | Pre-Booked Dining</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #0f172a; color: #f8fafc; font-family: 'Inter', sans-serif; }
        .glass { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center p-6">

    <header class="text-center mb-10">
        <h1 class="text-5xl font-bold tracking-tight text-amber-500 mb-2">ATMOSPHERE</h1>
        <p class="text-slate-400 italic">Pre-Booked Exclusive Dining</p>
        <div class="mt-4 text-sm text-slate-300">
            <p>📍 Foy's Lake Gate, Chittagong</p>
            <p>🕒 Open: 1:00 PM — 10:30 PM</p>
        </div>
    </header>

    <main class="w-full max-w-lg glass rounded-2xl p-8 shadow-2xl">
        <h2 class="text-2xl font-semibold mb-6 border-b border-slate-700 pb-2 text-center">Request a Table</h2>
        
        <form action="https://formspree.io/f/YOUR_UNIQUE_ID" method="POST" class="space-y-4">
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium mb-1">Full Name *</label>
                    <input type="text" name="name" required class="w-full bg-slate-800 border border-slate-600 rounded-lg p-2.5 focus:ring-2 focus:ring-amber-500 outline-none">
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1">Phone Number *</label>
                    <input type="tel" name="phone" required class="w-full bg-slate-800 border border-slate-600 rounded-lg p-2.5 focus:ring-2 focus:ring-amber-500 outline-none">
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium mb-1">Total Pax *</label>
                    <input type="number" name="pax" min="1" required class="w-full bg-slate-800 border border-slate-600 rounded-lg p-2.5 focus:ring-2 focus:ring-amber-500 outline-none">
                </div>
                <div>
                    <label class="block text-sm font-medium mb-1">Arrival Date *</label>
                    <input type="date" name="date" required class="w-full bg-slate-800 border border-slate-600 rounded-lg p-2.5 focus:ring-2 focus:ring-amber-500 outline-none">
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium mb-1">Arrival Time (1:00 PM - 10:30 PM) *</label>
                <input type="time" name="time" min="13:00" max="22:30" required class="w-full bg-slate-800 border border-slate-600 rounded-lg p-2.5 focus:ring-2 focus:ring-amber-500 outline-none">
            </div>

            <div>
                <label class="block text-sm font-medium mb-1">Address (Optional)</label>
                <textarea name="address" rows="2" class="w-full bg-slate-800 border border-slate-600 rounded-lg p-2.5 focus:ring-2 focus:ring-amber-500 outline-none"></textarea>
            </div>

            <button type="submit" class="w-full bg-amber-600 hover:bg-amber-500 transition-colors text-white font-bold py-3 rounded-lg mt-4 shadow-lg">
                Confirm Pre-Booking
            </button>
        </form>
    </main>

    <footer class="mt-12 text-slate-500 text-sm">
        &copy; 2026 Atmosphere Restaurant. All rights reserved.
    </footer>

</body>
</html>
